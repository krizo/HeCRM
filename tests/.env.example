# HeCRM test-suite configuration
#
# Copy to `.env` (gitignored) and flip values as needed. `playwright.config.ts`
# loads this file via dotenv before any test runs — IDE invocations pick it up
# the same way `npm run test:*` does.

# ============================================
# Dev toggles — most frequently flipped
# ============================================

# Run the UI browser with a visible window. Flip to `false` to watch tests
# drive the app. Has no effect on the `api` project.
HECRM_HEADLESS=true

# Slow every UI action (click / fill / navigation) down by N ms. Great with
# HECRM_HEADLESS=false for step-by-step debugging. 0 = no delay.
HECRM_SLOWMO_MS=0

# Log level for the in-test Logger: debug | info | warn | error
HECRM_LOG_LEVEL=info

# ============================================
# Endpoints
# ============================================

HECRM_API_BASE_URL=http://127.0.0.1:8000/api
HECRM_UI_BASE_URL=http://127.0.0.1:5173

# ============================================
# Test data conventions
# ============================================
# Must match scripts/seed.py prefixes. Changing this without re-seeding the
# backend will break the cleanup step (DataCollector).

HECRM_ACCOUNT_PREFIX=HECRM-
HECRM_PRODUCT_PREFIX=HCR-

# ============================================
# Auth (reserved for future protected endpoints / UI login)
# ============================================

HECRM_AUTH_USERNAME=
HECRM_AUTH_PASSWORD=
HECRM_AUTH_TENANT_ID=

# ============================================
# Dataverse contract tests (project: dataverse)
# ============================================
# All four must be set for the `dataverse` project to run; otherwise its
# tests skip with a clear message. Same values as backend/.env.

HECRM_DATAVERSE_URL=
HECRM_AZURE_TENANT_ID=
HECRM_AZURE_CLIENT_ID=
HECRM_AZURE_CLIENT_SECRET=

# ============================================
# Tuning
# ============================================

HECRM_REQUEST_TIMEOUT_MS=30000
HECRM_DEFAULT_RETRIES=0
