{
  "name": "hecrm-tests",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test:api": "playwright test --project=api",
    "test:api:verbose": "playwright test --project=api --reporter=./src/reporters/JourneyReporter.ts,list",
    "test:ui": "playwright test --project=ui",
    "test:ui:verbose": "playwright test --project=ui --reporter=./src/reporters/JourneyReporter.ts,list",
    "test": "playwright test",
    "report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.0.0",
    "dotenv": "^16.4.5",
    "eslint": "^10.2.1",
    "eslint-plugin-playwright": "^2.10.2",
    "globals": "^17.5.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.0"
  }
}
