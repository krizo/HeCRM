# HeCRM test-suite configuration
#
# Copy to `.env` and adjust for your local / CI setup.
# All of these also double as `process.env.*` so you can override on the CLI:
#   HECRM_API_BASE_URL=http://10.0.0.5:8000/api npm run test:api

# ---- Endpoints ----
HECRM_API_BASE_URL=http://127.0.0.1:8000/api
HECRM_UI_BASE_URL=http://127.0.0.1:5173

# ---- Auth (reserved for future-protected endpoints / UI login) ----
HECRM_AUTH_USERNAME=
HECRM_AUTH_PASSWORD=
HECRM_AUTH_TENANT_ID=

# ---- Seed / test-data conventions ----
# Must match scripts/seed.py prefixes. Changing this without re-seeding the
# backend will break the cleanup step (DataCollector).
HECRM_ACCOUNT_PREFIX=HECRM-
HECRM_PRODUCT_PREFIX=HCR-

# ---- Test run tuning ----
HECRM_REQUEST_TIMEOUT_MS=30000
HECRM_DEFAULT_RETRIES=0

# ---- UI test visuals ----
# Run Chromium with a visible window instead of headless. Default: headless.
# HECRM_HEADLESS=false
#
# Slow every UI action down by N ms so you can follow it visually. Default: 0.
# HECRM_SLOWMO_MS=250
